# AI 科研写作与文献研究工作台 - 环境变量配置

# ============================================
# AI 模型配置
# ============================================

# 火山引擎 DeepSeek (默认模型)
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=ep-20251207150153-m8xqp

# OpenAI GPT
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-pro

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 默认使用的模型提供商 (ark | openai | google | anthropic)
DEFAULT_LLM_PROVIDER=ark

# ============================================
# 学术数据库 API 配置
# ============================================

# Web of Science API
WOS_API_KEY=your_wos_api_key_here

# Scopus API (Elsevier)
# API Key 和 Insttoken 配对使用，insttoken 由机构申请获得
# 安全要求: insttoken 只能在服务端使用，不能暴露到浏览器
SCOPUS_API_KEY=your_scopus_api_key_here
SCOPUS_INSTTOKEN=your_scopus_insttoken_here

# ============================================
# DOI 摘要抓取配置
# ============================================

# 全局并发数（默认 15）
DOI_ABSTRACT_CONCURRENCY=15

# 单域名并发数（默认 3，避免被出版商限流）
DOI_ABSTRACT_PER_HOST=3

# 单篇超时时间（毫秒，默认 12000）
DOI_ABSTRACT_TIMEOUT_MS=12000

# ============================================
# 数据存储模式
# ============================================

# 存储后端: supabase | sqlite
STORAGE_PROVIDER=supabase

# SQLite 本地数据库文件（相对于 DATA_DIR，或使用绝对路径）
SQLITE_DB_PATH=app.db

# ============================================
# Supabase 配置（仅 STORAGE_PROVIDER=supabase 时使用）
# ============================================

SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# 安全配置
# ============================================

# 设置加密密钥（用于加密存储在数据库中的 API Key）
# 生成方式: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=your_random_encryption_key_here

# ============================================
# 应用配置
# ============================================

# 服务端口
PORT=8000

# 运行环境 (development | production)
NODE_ENV=development

# 本地数据存储目录
DATA_DIR=./data

# 日志级别 (debug | info | warn | error)
LOG_LEVEL=info
